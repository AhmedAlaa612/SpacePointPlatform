*.sqlite3

# Generated documents / uploads (should live in Supabase Storage, not git)
backend/app/static/generated/
backend/uploads/

# Legacy ETL (GO_LIVE.md A4) id-maps — audit artifacts from migrate_legacy.py
# runs. Even the "safe-looking" tables can carry real names/emails/titles
# depending on the source DB, so the whole directory is gitignored rather
# than picking file-by-file; keep locally for audit, don't commit.
backend/scripts/migration_id_maps/

# Local letterhead design sandbox — scratch space for iterating on the
# document header/footer, not part of the shipped app.
backend/tools/letterhead_lab/

# Docs & internal notes — not for the repo
*.md

# Tooling
.claude/
.antigravity
.antigravity/

# Python venvs (non-standard names)
myenv/

# Plans
*.plan
