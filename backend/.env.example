# ── Database ────────────────────────────────────────────────────────────────
# Supabase session pooler (port 5432). asyncpg requires statement_cache_size=0
# which is set in app/db/session.py.
DATABASE_URL=postgresql+asyncpg://postgres:[password]@[host]:5432/postgres

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-32-plus-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase Storage ────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SpacePoint <noreply@spacepoint.ae>

# ── App ─────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
ADMIN_EMAIL=admin@spacepoint.local
ADMIN_PASSWORD=changeme
DEFAULT_SIGNATORY_NAME=ABDULLAH ALSALMANI
DEFAULT_SIGNATORY_TITLE=Co-Founder & CEO of SpacePoint
